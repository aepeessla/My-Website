text = """<select id="cars">
<option value="volvo">Volvo</option>
  <option value="saab">Saab</option>
  <option value="opel">Opel</option>
  <option value="audi">Audi</option>
</select>"""

text_bearbeitet = ""

for i in text:
    if i == "<":
        text_bearbeitet += "&lt;"
    elif i == ">":
        text_bearbeitet += "&gt;"
    else:
        text_bearbeitet += i

print(text_bearbeitet)